<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg">

    <!-- Radial glow behind the alien image -->
    <ImageView
        android:id="@+id/imageGlow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/glow_radial_green"
        android:alpha="0.85"
        app:layout_constraintWidth_percent="1.0"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@null" />

    <!-- The alien silhouette (diamond image) -->
    <ImageView
        android:id="@+id/imageAlienBig"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.78"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/textName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_alien_placeholder"
        android:contentDescription="@null" />

    <!-- Alien name label at the bottom -->
    <TextView
        android:id="@+id/textName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/omnitrix_green"
        android:textStyle="bold"
        android:textSize="16sp"
        android:letterSpacing="0.12"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="GREY MATTER" />

</androidx.constraintlayout.widget.ConstraintLayout>
